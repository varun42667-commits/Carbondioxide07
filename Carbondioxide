        -- Click flash
        TweenService:Create(Btn, TweenInfo.new(0.07), {
            BackgroundColor3 = Color3.fromRGB(0, 200, 80)
        }):Play()
        task.delay(0.1, function()
            TweenService:Create(Btn, TweenInfo.new(0.15), {
                BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            }):Play()
        end)
        callback()
    end)

    return Btn
