-- [ FUZZY SEARCH ENGINE ] ------------------------------------
local SearchEngine = {}

local function levenshtein(s, t)
    local m, n = #s, #t
    if m == 0 then return n end
    if n == 0 then return m end

    local matrix = {}
    for i = 0, m do
        matrix[i] = {[0] = i}
    end
    for j = 0, n do
        matrix[0][j] = j
    end

    for i = 1, m do
        for j = 1, n do
            local cost = (s:sub(i,i) == t:sub(j,j)) and 0 or 1
            matrix[i][j] = math.min(
                matrix[i-1][j] + 1,
                matrix[i][j-1] + 1,
                matrix[i-1][j-1] + cost
            )
        end
    end

    return matrix[m][n]
end

local function similarity(a, b)
    a = a:lower()
    b = b:lower()
    if b:find(a, 1, true) then return 1.0 end
    local dist = levenshtein(a, b)
    local maxLen = math.max(#a, #b)
    return maxLen > 0 and (1 - dist / maxLen) or 1.0
end

local function windowSimilarity(query, target)
    query  = query:lower()
    target = target:lower()
    if #query == 0 then return 1.0 end
    if #query > #target then
        return similarity(query, target)
    end
    local best = 0
    for i = 1, #target - #query + 1 do
        local window = target:sub(i, i + #query - 1)
        local s = similarity(query, window)
        if s > best then best = s end
    end
    return best
end

function SearchEngine.match(query, label)
    if query == "" then return 1.0 end
    local score = windowSimilarity(query, label)
    local labelLower = label:lower()
    local queryLower = query:lower()
    for word in labelLower:gmatch("%S+") do
        if word:sub(1, #queryLower) == queryLower then
            score = math.max(score, 0.85)
            break
        end
    end
    return score
end

