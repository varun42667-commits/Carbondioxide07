-- [ HIGHLIGHT ] ----------------------------------------------
local function applyHighlight(button, query)
    local label = button:FindFirstChildWhichIsA("TextLabel") or button

    if not label then return end

    local original = label:GetAttribute("OriginalText") or label.Text
    label:SetAttribute("OriginalText", original)

    if not label:GetAttribute("OriginalColor") then
        label:SetAttribute("OriginalColor", label.TextColor3)
    end

    if query == "" then
        label.RichText = false
        label.Text = original
        label.TextColor3 = label:GetAttribute("OriginalColor")
        return
    end

    local lower = original:lower()
    local qLower = query:lower()
    local s, e = lower:find(qLower, 1, true)

    if s then
        label.RichText = true
        local pre  = original:sub(1, s-1)
        local mid  = original:sub(s, e)
        local post = original:sub(e+1)
        label.Text = string.format(
            '%s<font color="rgb(0,255,128)"><b>%s</b></font>%s',
            pre, mid, post
        )
    else
        label.RichText = false
        label.Text = original
    end
end

-- [ SEARCH CONTROLLER ] --------------------------------------
local SearchController = {}
SearchController.__index = SearchController

function SearchController.new(contentFrame, buttonContainer)
    local self = setmetatable({}, SearchController)
    self.ContentFrame = contentFrame
    self.ButtonFrame  = buttonContainer or contentFrame
    self.LastQuery    = ""
    self.Debounce     = false
    self.Buttons      = {}

    local _, inputBox, clearBtn = SearchUI.createBar(contentFrame)
    self.InputBox = inputBox
    self.ClearBtn = clearBtn

    task.defer(function()
        self:refresh()
        self:_connect()
        print("[Search] Ready. Buttons found:", #self.Buttons)
    end)

    return self
end

function SearchController:refresh()
    self.Buttons = {}
    for _, child in ipairs(self.ButtonFrame:GetChildren()) do
        if (child:IsA("TextButton") or child:IsA("ImageButton"))
            and child.Name ~= "ClearButton" then
            table.insert(self.Buttons, child)
        end
    end
end

function SearchController:_filter(query)
    query = query:match("^%s*(.-)%s*$")

    for _, btn in ipairs(self.Buttons) do
        local label = btn:FindFirstChildWhichIsA("TextLabel")
        local text  = label and label.Text or btn.Text
        text = text:gsub("<[^>]+>", "")

        local score   = SearchEngine.match(query, text)
        local visible = (query == "") or (score >= SEARCH_CONFIG.FuzzyThreshold)

        btn.Visible = visible
        if visible then
            applyHighlight(btn, query)
        end
    end

    self.ClearBtn.Visible = (query ~= "")
end

function SearchController:_connect()
    self.InputBox:GetPropertyChangedSignal("Text"):Connect(function()
        if self.Debounce then return end
        self.Debounce = true

        task.delay(SEARCH_CONFIG.DebounceTime, function()
            self.Debounce = false
            local query = self.InputBox.Text
            if query ~= self.LastQuery then
                self.LastQuery = query
                self:_filter(query)
            end
        end)
    end)

    self.ClearBtn.MouseButton1Click:Connect(function()
        self.InputBox.Text = ""
        self.InputBox:CaptureFocus()
        self:_filter("")
    end)
end

